---
const today = new Date();

interface Props {
	theme?: 'default' | 'dark';
}

const { theme = 'default' } = Astro.props;
---

<footer class:list={['site-footer', { 'site-footer--dark': theme === 'dark' }]}>
	<p class="footer-copy">&copy; {today.getFullYear()} Apsis Concepts. All rights reserved.</p>
</footer>
<style>
	.site-footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	.site-footer--dark {
		background: transparent;
		color: #94a3b8;
		border-top: 1px solid rgba(255, 255, 255, 0.06);
		padding-top: 2.5rem;
	}
	.footer-copy {
		margin: 0;
		font-size: 0.95rem;
	}
</style>
