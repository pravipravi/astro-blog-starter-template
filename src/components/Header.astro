---
import HeaderLink from './HeaderLink.astro';
import ApsisLogo from './ApsisLogo.astro';

interface Props {
	theme?: 'default' | 'dark';
}

const { theme = 'default' } = Astro.props;
---

<header class:list={['site-header', { 'site-header--dark': theme === 'dark' }]}>
	<nav>
		<ApsisLogo />
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/#services">Services</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/#contact">Contact</HeaderLink>
		</div>
	</nav>
</header>
<style>
	.site-header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	.site-header--dark {
		background: rgba(10, 12, 16, 0.85);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		box-shadow: 0 1px 0 rgba(255, 255, 255, 0.06);
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}
	.site-header--dark :global(.apsis-logo-name) {
		color: #f1f5f9;
	}
	.site-header--dark :global(.apsis-logo-sub) {
		color: #94a3b8;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.internal-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 0.15rem;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--black));
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	.site-header--dark nav a {
		color: #cbd5e1;
	}
	.site-header--dark nav a:hover {
		color: #f1f5f9;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.site-header--dark nav a.active {
		border-bottom-color: #34d399;
		color: #f1f5f9;
	}
	@media (max-width: 900px) {
		.internal-links :global(a) {
			padding: 0.65em 0.35em;
			font-size: 0.9rem;
		}
	}
	@media (max-width: 720px) {
		.internal-links {
			justify-content: flex-end;
		}
	}
</style>
