---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import '../styles/apsis-landing.css';

const title = `About — ${SITE_TITLE}`;
const description =
	'Learn how Apsis Concepts works with product and engineering teams to ship dependable software.';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body class="apsis-landing">
		<Header theme="dark" />
		<main>
			<section class="apsis-hero" aria-labelledby="about-heading">
				<div class="apsis-hero-inner">
					<span class="apsis-eyebrow">About Apsis Concepts</span>
					<h1 id="about-heading">Built for teams that outgrow ad hoc engineering</h1>
					<p class="apsis-hero-lead">
						We are a software company focused on clarity: honest scoping, pragmatic architecture,
						and delivery that does not crumble when traffic or complexity grows.
					</p>
					<div class="apsis-hero-cta">
						<a class="apsis-btn apsis-btn--primary" href="/#contact">Work with us</a>
						<a class="apsis-btn apsis-btn--ghost" href="/">Back to home</a>
					</div>
				</div>
			</section>

			<section class="apsis-section apsis-prose" aria-labelledby="mission-heading">
				<h2 id="mission-heading">Mission</h2>
				<p>
					Apsis Concepts exists to help organizations ship software that stays understandable—by the
					people who build it and the teams who rely on it. We bias toward small, composable
					services, observable systems, and documentation that earns its place on the shelf.
				</p>
				<h2>Values</h2>
				<ul>
					<li>
						<strong>Transparency</strong> — estimates tied to assumptions; risks named early.
					</li>
					<li>
						<strong>Craft</strong> — code review, automated checks, and operational readiness as
						defaults.
					</li>
					<li>
						<strong>Partnership</strong> — we succeed when your team can own the result without us.
					</li>
				</ul>
				<h2>Who we work with</h2>
				<p>
					Product-led companies, funded startups, and internal IT groups modernizing critical
					workflows. If you need a steady engineering partner—not a black box—this is the kind of
					relationship we optimize for.
				</p>
				<p>
					For writing and updates from the team, see the <a href="/blog">blog</a>. To discuss a
					project, use the <a href="/#contact">contact section</a> on the home page.
				</p>
			</section>
		</main>
		<Footer theme="dark" />
	</body>
</html>
